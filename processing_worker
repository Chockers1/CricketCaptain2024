import pandas as pd
import os
import tempfile
import shutil
import traceback

# Import your original, working processing functions
# This worker file must be in the same directory as these scripts to find them.
from match import process_match_data
from game import process_game_stats
from bat import process_bat_stats
from bowl import process_bowl_stats

def process_single_file_worker(file_path):
    """
    This is the "job" for each CPU core. It runs your full, original pipeline
    on a SINGLE file path. Because this function is in its own file, it is
    guaranteed to be "pickle-safe" for multiprocessing.
    """
    filename = os.path.basename(file_path)
    
    # Create a unique, isolated temporary directory for this single file
    # This prevents race conditions where multiple processes might interfere.
    with tempfile.TemporaryDirectory() as worker_temp_dir:
        worker_file_path = os.path.join(worker_temp_dir, filename)
        # Copy the file to the isolated directory
        shutil.copy(file_path, worker_file_path)

        try:
            # Now, run your original functions, which are designed to process a directory.
            # Since this directory only has one file, they will correctly process just that file.
            match_df = process_match_data(worker_temp_dir)
            if match_df is None or match_df.empty: return None

            game_df = process_game_stats(worker_temp_dir, match_df)
            if game_df is None or game_df.empty: return None

            bat_df = process_bat_stats(worker_temp_dir, game_df, match_df)
            bowl_df = process_bowl_stats(worker_temp_dir, game_df, match_df)
            
            # Return the complete set of dataframes for this one file
            return (bat_df, bowl_df, match_df)

        except Exception as e:
            # Print a detailed error for the specific file that failed
            print(f"--- Error processing file: {filename} in worker ---")
            print(traceback.format_exc())
            print("----------------------------------------------------")
            return None # Return None if this specific file fails
